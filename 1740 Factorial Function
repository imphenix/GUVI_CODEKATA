#include <stdio.h>

long long findFactorial(int n) {
    long long fact = 1;

    if (n < 0) return 0; 
    
    for (int i = 1; i <= n; i++) {
        fact *= i;
    }
    return fact;
}

int main() {
    int n;
    if (scanf("%d", &n) == 1) {
        printf("%lld", findFactorial(n));
    }
    return 0;
}
